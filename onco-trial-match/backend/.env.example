# --- App ---
ENV=development
DEBUG=true

# --- PostgreSQL ---
POSTGRES_USER=onco_user
POSTGRES_PASSWORD=onco_pass
POSTGRES_DB=onco_trials
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_TRIALS=trial_eligibility

# --- ClinicalTrials.gov ---
CLINICALTRIALS_API_BASE=https://clinicaltrials.gov/api/v2

# --- LLM ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
LLM_MODEL=gemini-2.5-flash

# --- Embeddings ---
BIOBERT_MODEL_NAME=pritamdeka/S-BioBert-snli-multinli-stsb